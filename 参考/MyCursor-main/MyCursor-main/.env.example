# MyCursor Environment Variables

# Development/Production mode
# Values: development | production
NODE_ENV=development

# Enable logging in production (default: false)
# Set to "true" to enable logging in production builds
VITE_ENABLE_LOGGING=false

# Log level (default: info)
# Values: debug | info | warn | error
VITE_LOG_LEVEL=info

# Tauri specific variables (automatically set by Tauri)
# TAURI_PLATFORM=windows
# TAURI_ARCH=x86_64
# TAURI_FAMILY=windows
# TAURI_PLATFORM_VERSION=10.0.22000
# TAURI_PLATFORM_TYPE=windows
